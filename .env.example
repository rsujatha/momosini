# Names only — never put real values here. Copy to .env (git-ignored) and fill locally.

# Default model: Gemini via Google AI Studio. Needed unless you switch ADK_MODEL away from Gemini.
GOOGLE_API_KEY=

# Optional: switch the model backend. Gemini is the default if unset.
#   ADK_MODEL=gemini-2.5-flash            # default
#   ADK_MODEL=gemini-2.5-flash-lite       # lighter Gemini (less likely to hit overload)
#   ADK_MODEL=deepseek/deepseek-chat      # test on DeepSeek (needs: pip install litellm)
ADK_MODEL=

# Only needed when ADK_MODEL is a deepseek/* model (routed via LiteLlm).
DEEPSEEK_API_KEY=
