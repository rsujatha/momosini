# Names only — never put real values here. Copy to .env (git-ignored) and fill locally.
#
# Pick ONE of the three backend profiles below. Switching is env-only — no code change.
# ─────────────────────────────────────────────────────────────────────────────────────

# ── Profile A: DeepSeek (via LiteLlm) ──────────────────────────────────────────────────
# ADK_MODEL=deepseek/deepseek-chat
# DEEPSEEK_API_KEY=            # required for this profile (needs: pip install litellm)

# ── Profile B: Gemini via Google AI Studio ─────────────────────────────────────────────
# Note: the $300 free-trial credit does NOT cover AI Studio Gemini for accounts made after
# Mar 2026 — this profile bills your GOOGLE_API_KEY directly (free tier may be enough).
# ADK_MODEL=gemini-3.5-flash
# GOOGLE_API_KEY=

# ── Profile C: Gemini via Vertex AI (uses Cloud free-trial credit, no API key) ──────────
# ADC auth — locally run `gcloud auth application-default login`; on Cloud Run the service
# account provides ADC automatically. Enable the Vertex AI API on the project.
# ADK_MODEL=gemini-3.5-flash
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global      # 3.x Gemini is served on the global endpoint; it 404s on
#                                   # regional ones like us-central1. (2.5-flash works regionally.)

# ─────────────────────────────────────────────────────────────────────────────────────
# Active values (uncomment from a profile above, or set here). Gemini AI Studio is the
# default if ADK_MODEL is unset.
ADK_MODEL=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
